FrameWidgetClass rootFrame {
 size 1500 750
 halign center_ref
 valign center_ref
 hexactpos 1
 vexactpos 1
 hexactsize 1
 vexactsize 1
 {
  ImageWidgetClass BackgroundImage {
   ignorepointer 1
   position 0 -0.00119
   size 1 1
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   imageTexture "{6878A9FF9CF2F671}ZenMods/ZenMapLinkChat/data/gui/images/background.edds"
   mode blend
   "src alpha" 1
   "clamp mode" invalid
   "stretch mode" stretch_w_h
   {
    PanelWidgetClass MainPanel {
     ignorepointer 1
     position 0.16 0.09
     size 0.67 0.81
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     {
      TextListboxWidgetClass ChatTextList {
       visible 1
       ignorepointer 0
       position 0.01 0.1
       size 0.98 0.8
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 0
       style Default
       "title visible" 1
       colums "LOCATION;12;TIME SENT;12;IDENTITY;20;MESSAGE;60;"
       lines 999
       "highlight row" 1
       font "gui/fonts/metronbook-bold22"
      }
      EditBoxWidgetClass ChatEditBox {
       position 0.01 0
       size 0.75 0.1
       valign bottom_ref
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 0
       text "Enter message..."
       "limit visible" 1
       "Use default text" 1
       "exact text" 1
       font "gui/fonts/metronlight28"
      }
      ButtonWidgetClass SendChatButton {
       position 0.02176 0
       size 0.21824 0.1
       halign right_ref
       valign bottom_ref
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 0
       style InventoryActionMenu
       text "SEND"
      }
      ImageWidgetClass BatteryImage {
       ignorepointer 1
       position 0.06 0.01
       size 47 25
       halign right_ref
       hexactpos 0
       vexactpos 0
       hexactsize 1
       vexactsize 1
       imageTexture "{2657D273C6E31AD4}ZenMods/ZenMapLinkChat/data/gui/images/battery.edds"
       mode blend
       "src alpha" 1
       "clamp mode" clamp
       "stretch mode" stretch_w_h
       {
        ProgressBarWidgetClass BatteryLevel {
         ignorepointer 1
         position 0.1 0.2
         size 0.72 0.61
         hexactpos 0
         vexactpos 0
         hexactsize 0
         vexactsize 0
         style Quantity
        }
       }
      }
      MultilineTextWidgetClass TitleText {
       clipchildren 1
       ignorepointer 1
       color 0.6863 0.2588 0.2588 1
       position 0 0
       size 0.5 0.09
       halign center_ref
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 0
       style DayZBold
       text "You can only send one message every 3 seconds! Please don't spam the server."
       "exact text" 1
       "size to text h" 0
       "size to text v" 0
       "text halign" center
       "text valign" center
       wrap 1
      }
      ButtonWidgetClass BanButton {
       position 0.05 0.025
       size 0.15 0.05
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 0
       style MenuDefault
       text "BAN SELECTED PLAYER"
       font "gui/fonts/metron-bold16"
      }
      ImageWidgetClass MuteImage {
       ignorepointer 1
       position 0.8394 -0.01
       size 48 48
       hexactpos 0
       vexactpos 0
       hexactsize 1
       vexactsize 1
       imageTexture "{42038C14C995BC8B}ZenMods/ZenMapLinkChat/data/gui/images/mute_off.edds"
       mode blend
       "src alpha" 1
       "clamp mode" clamp
       "stretch mode" stretch_w_h
       {
        ButtonWidgetClass MuteButton {
         position 0 0
         size 1 1
         hexactpos 0
         vexactpos 0
         hexactsize 0
         vexactsize 0
        }
       }
      }
      ImageWidgetClass PowerImage {
       ignorepointer 1
       position 0.95 0.01
       size 25 25
       hexactpos 0
       vexactpos 0
       hexactsize 1
       vexactsize 1
       imageTexture "{3E2AB60B15713B2A}ZenMods/ZenMapLinkChat/data/gui/images/power.edds"
       mode blend
       "src alpha" 1
       "clamp mode" clamp
       "stretch mode" stretch_w_h
       {
        ButtonWidgetClass PowerButton {
         position 0 0
         size 1 1
         hexactpos 0
         vexactpos 0
         hexactsize 0
         vexactsize 0
        }
       }
      }
     }
    }
   }
  }
 }
}